{
	"name": "shelf-life",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "npm run prepare:environment && lefthook install && (playwright install || echo '') && (svelte-kit sync || echo '')",
		"prepare:environment": "node scripts/prepare-environment.mjs",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest run",
		"test:e2e": "drizzle-kit push --force && playwright test --project=setup --project=public --project=authenticated",
		"test:e2e:cross-browser": "drizzle-kit push --force && playwright test --project=firefox-smoke --project=webkit-smoke",
		"test": "npm run test:unit && npm run test:e2e",
		"build:stats": "BUNDLE_STATS=1 vite build",
		"performance:build": "npm run build:stats && node scripts/check-performance-budgets.mjs",
		"performance:runtime": "drizzle-kit push --force && playwright test tests/end-to-end/performance.spec.ts --project=authenticated",
		"performance:check": "npm run performance:build && npm run performance:runtime",
		"dossier": "tsx scripts/summarize-failure-dossier.ts",
		"knip": "DATABASE_URL=file:./tmp/knip.db knip",
		"test:smoke": "playwright test --config=playwright.smoke.config.ts",
		"test:e2e:lab-fixtures": "drizzle-kit push --force && playwright test --config=playwright.labs.config.ts --project=setup --project=labs-fixtures",
		"test:e2e:admin-setup": "drizzle-kit push --force && playwright test --config=playwright.labs.config.ts --project=admin-setup",
		"traces:generate": "node scripts/generate-lab-traces.mjs",
		"traces:clean": "rm -rf playwright-report/lab-traces",
		"pre-push": "npm run typecheck && npm run knip && npm run test:unit",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.1",
		"@better-auth/cli": "1.4.22",
		"@eslint/compat": "2.0.5",
		"@eslint/js": "10.0.1",
		"@libsql/client": "0.17.2",
		"@modelcontextprotocol/sdk": "1.29.0",
		"@playwright/test": "1.59.1",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/kit": "2.57.1",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "4.2.2",
		"@types/node": "25.6.0",
		"better-auth": "1.6.2",
		"drizzle-kit": "0.31.10",
		"drizzle-orm": "0.45.2",
		"eslint": "10.2.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.0",
		"globals": "17.5.0",
		"knip": "6.4.1",
		"lefthook": "2.1.5",
		"playwright": "1.59.1",
		"prettier": "3.8.2",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"rollup-plugin-visualizer": "7.0.1",
		"svelte": "5.55.3",
		"svelte-check": "4.4.6",
		"tailwindcss": "4.2.2",
		"tsx": "4.21.0",
		"typescript": "6.0.2",
		"typescript-eslint": "8.58.2",
		"vite": "8.0.8",
		"vitest": "4.1.4",
		"zod": "4.3.6"
	}
}
